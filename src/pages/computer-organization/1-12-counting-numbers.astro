---
import BinDecHexCounter from "../../components/interactives/BinDecHexCounter.astro";
import Divider from "../../components/ui/Divider.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div class="container mt-4">
    <a href="/computer-organization/" class="btn btn-sm btn-outline-light">
      ← Back
    </a>
    <h2 class="text-center mt-5 text-cyber-primary">
      Activity 1.12 Counting Numbers
    </h2>
    <Divider variant="3" classes="my-4" />
    <div class="row">
      <div class="col-sm-12 col-md-6 offset-md-3">
        <BinDecHexCounter />
      </div>
    </div>
  </div>
</Layout>
