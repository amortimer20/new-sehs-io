---
import Divider from "../../components/Divider.astro";
import PracticeSet from "../../components/PracticeSet.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div class="container mt-4">
    <a
      href="/computer-organization/"
      class="btn btn-sm cyber-btn cyber-btn-secondary-6 btn-shadow-secondary"
    >
      ← Back
    </a>
    <h2 class="text-center mt-5 text-eds-gold">
      Activity 1.5 Decimal to Binary Practice 2
    </h2>
    <Divider variant="3" classes="my-4" />
    <div class="row">
      <div class="col">
        <h3>Introduction</h3>
        <p>
          For each decimal number, write the corresponding binary number.
        </p>
      </div>
    </div>
    <div class="row my-5">
      <div class="col-sm-12 col-md-6 offset-md-3">
        <PracticeSet dataUrl="/json/dec-bin-2.json" />
      </div>
    </div>
  </div>
</Layout>
