---
import Layout from "../layouts/Layout.astro";
import CourseCard from "../components/ui/CourseCard.astro";
import Divider from "../components/ui/Divider.astro";
import CyberListItem from "../components/ui/CyberListItem.astro";

import codeChallImg from "../assets/courses/code-challenges/img/code-challenges-thumbnail.png";
import compOrgImg from "../assets/courses/computer-organization/img/computer-organization-thumbnail.png";
import javaImg from "../assets/courses/java-programming/img/java-thumbnail.png";
import pythonImg from "../assets/courses/python-programming/img/python-thumbnail.png";
import skynestLogo from "../assets/img/misc/skynest-emblem-green.svg";
import { Image } from "astro:assets";
---

<Layout>
  <!-- Hero Unit -->
  <div class="bg-cyber-dark mb-3">
    <canvas id="matrix" style="position: absolute;"></canvas>
    <h1 class="text-center text-eds-green pt-5 animation-overlay">
      St. Edward High School
    </h1>
    <h4 class="text-center text-eds-gold animation-overlay">
      Computer science and Other Stuff
    </h4>
    <Image
      id="skynestLogo"
      src={skynestLogo}
      class="d-block mx-auto img-fluid w-25 animation-overlay"
      alt="SkyNest Logo"
      title="Click Me"
    />
  </div>
  <section class="container mb-3 p-1">
    <!-- Course Content -->
    <h3 class="text-center py-3">Content</h3>
    <div class="row mb-3">
      <div class="col-sm-12 col-md-4 col-lg-3 my-3">
        <CourseCard link="#" img={pythonImg} title="Python Programming" />
      </div>
      <div class="col-sm-12 col-md-4 col-lg-3 my-3">
        <CourseCard
          link="/computer-organization/"
          img={compOrgImg}
          title="Computer Organization"
        />
      </div>
      <div class="col-sm-12 col-md-4 col-lg-3 my-3">
        <CourseCard link="#" img={javaImg} title="Java Programming" />
      </div>
      <div class="col-sm-12 col-md-4 col-lg-3 my-3">
        <CourseCard link="#" img={codeChallImg} title="Code Challenges" />
      </div>
    </div>
    <Divider variant="9" />
    <!-- Guides/Utilities -->
    <div class="row mb-3">
      <div class="col-sm-12 col-md-6">
        <h4 class="text-center py-3">Guides</h4>
      </div>
      <div class="col-sm-12 col-md-6">
        <h4 class="text-center py-3">Utilities</h4>
        <ul>
          <CyberListItem>
            <a href="/utilities/color-picker">RGB Color Picker</a>
          </CyberListItem>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { animate } from "animejs";
  import { matrixAnimation } from "../scripts/animations/matrix-animation";

  matrixAnimation("matrix");

  // Spinning Logo
  (() => {
    let delta = 0;
    const logo = document.querySelector<HTMLImageElement>("#skynestLogo");
    if (!logo) return;

    logo.onclick = (ev) => {
      delta += 10;
      animate(logo, { rotate: `+=${delta}` });
    };

    logo.onmouseout = (ev) => {
      animate(logo, { rotate: 0 });
      delta = 0;
    };
  })();
</script>
