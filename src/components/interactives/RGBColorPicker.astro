---

---

<section x-data="colorPicker">
  <div class="row">
    <div class="col-sm-12 col-md-6 my-auto">
      <label class="form-label">Red: <span x-text="r"></span></label>
      <input
        type="range"
        class="form-range"
        min="0"
        max="255"
        step="1"
        x-model="r"
      />
      <label class="form-label">Green: <span x-text="g"></span></label>
      <input
        type="range"
        class="form-range"
        min="0"
        max="255"
        step="1"
        x-model="g"
      />
      <label class="form-label" for="blue">Blue: <span x-text="b"></span></label
      >
      <input
        type="range"
        class="form-range"
        min="0"
        max="255"
        step="1"
        x-model="b"
      />
      <p>Hex: #<span x-text="hex"></span></p>
    </div>
    <div class="col-sm-12 col-md-6">
      <div class="color-square" :style="`background-color: #${hex}`"></div>
    </div>
  </div>
</section>

<script>
  import Alpine from "alpinejs";

  interface ColorPicker {
    r: string;
    g: string;
    b: string;
    get hex(): string;
  }

  let colorPicker: ColorPicker = {
    r: "0",
    g: "0",
    b: "0",
    get hex() {
      const toHex = (val: string): string =>
        parseInt(val).toString(16).toUpperCase().padStart(2, "0");
      return toHex(this.r) + toHex(this.g) + toHex(this.b);
    },
  };

  document.addEventListener("alpine:init", () => {
    Alpine.data("colorPicker", () => colorPicker);
  });
</script>

<style>
  .color-square {
    width: auto;
    height: 14rem;
    border: 3px solid black;
    border-radius: 5px;
  }
</style>
